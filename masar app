    protection:['سياسة حماية البيانات','سيتم عرض بنود حفظ البيانات وسجلات الاستخدام بشكل تفصيلي في صفحة مستقلة لاحقًا.'],
    terms:['الشروط والأحكام','سيتم إضافة الشروط والأحكام النهائية لاحقًا بعد اعتماد الصياغة الرسمية.'],
    reportPolicy:['سياسة البلاغات والمخالفات','البلاغات تُستخدم لتحسين المتابعة الميدانية، والمخالفات تُدار داخل بوابة الموظف بحسب الحالة.'],
    x:['حساب X','سيتم ربط حساب X الرسمي لاحقًا داخل النسخة النهائية.'],
    linkedin:['LinkedIn','سيتم ربط صفحة LinkedIn الرسمية لاحقًا داخل النسخة النهائية.']
  };

  function openFooterTopic(key){
    const topic = footerTopics[key] || ['مسار','المحتوى سيتوفر هنا لاحقًا.'];
    const modal = qs('#footerModal');
    if(!modal) return;
    const title = isEn() ? translateLooseText(topic[0]) : topic[0];
    const body = isEn() ? translateLooseText(topic[1]) : topic[1];
    qs('#footerModalTitle').textContent = title;
    qs('#footerModalBody').innerHTML = '<p style="margin:0;line-height:1.9">' + body + '</p>';
    modal.classList.add('active');
    modal.setAttribute('aria-hidden','false');
  }

  function closeFooterModal(){
    const modal = qs('#footerModal');
    if(!modal) return;
    modal.classList.remove('active');
    modal.setAttribute('aria-hidden','true');
  }

  function toggleLanguage(){
    state.lang = state.lang === 'ar' ? 'en' : 'ar';
    applyStaticLanguage();
    renderApp();
    normalizeLanguageUI();
  }

  document.addEventListener('DOMContentLoaded', function(){
    const supportBtn = qs('#entrySupportBtn');
    if(supportBtn) supportBtn.addEventListener('click', function(){ openFooterTopic('support'); });
    const reg = qs('#entryRegisterLink');
    if(reg) reg.addEventListener('click', function(){ openFooterTopic('citizenPortal'); });
    const forgot = qs('#entryForgotLink');
    if(forgot) forgot.addEventListener('click', function(){ openFooterTopic('support'); });
    setRole('citizen');
    applyStaticLanguage();
    renderAdminDataCenter();
    setInterval(function(){
      if(qs('#appScreen') && !qs('#appScreen').classList.contains('hidden')) renderAdminDataCenter();
    }, 60000);
    renderApp();
    normalizeLanguageUI();
    updateThemeButtons();
    document.addEventListener('click', function(e){
      const navBtn = e.target.closest('#navList .nav-item[data-page-target]');
      if(navBtn){
        const target = navBtn.dataset.pageTarget;
        if(target) showPage(target);
        return;
      }
      const wrap = qs('.menu-wrap');
      if(wrap && !wrap.contains(e.target)) closeAppMenu();
    });
  });
</script>
</body>
</html>
