.company-chart-card h4{margin:0 0 6px;font-size:18px;font-weight:900}.company-chart-card p{margin:0 0 14px;color:var(--muted);line-height:1.7;font-size:13px}
.company-donut{width:190px;height:190px;border-radius:50%;margin:6px auto 14px;position:relative}
.company-donut:after{content:"";position:absolute;inset:34px;border-radius:50%;background:var(--card);border:1px solid var(--line)}
.company-donut-center{position:absolute;inset:0;z-index:2;display:flex;align-items:center;justify-content:center;flex-direction:column;font-weight:900}.company-donut-center span{font-size:32px}.company-donut-center small{color:var(--muted);font-size:12px}
