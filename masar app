  function renderCompanyViolationsCharts(){ const el = qs('#companyViolationsCharts'); if(!el) return; const vs = state.companyViolations || []; const amount = v => Number(String(v.amount||'0').replace(/[^0-9.]/g,'')) || 0; el.innerHTML = `<div class="company-chart-grid">${companyDonut(isEn()?'Violation payment status':'حالة سداد المخالفات', isEn()?'Clear split between unpaid, disputed, due, and paid items.':'توزيع واضح بين غير مدفوعة، اعتراض، مستحقة، ومدفوعة.', companyTopRows(companyCountBy(vs,v=>isEn()?({'غير مدفوعة':'Unpaid','قيد الاعتراض':'Dispute','مستحقة':'Due','مدفوعة':'Paid'}[v.status]||v.status):v.status),5), vs.length)}${companyBars(isEn()?'Violation amount ranking':'ترتيب مبالغ المخالفات', isEn()?'Highest financial exposure appears first.':'أعلى أثر مالي يظهر أولًا.', vs.slice().sort((a,b)=>amount(b)-amount(a)).map(v=>[v.id, amount(v)]))}</div>`; }
