  function empSafeLabel(v, fallback){ return escHtml(String(v || fallback || '—')); }
  function empCounts(items, keyFn){ return groupSum(items || [], keyFn || (x=>x)); }
  function empTopRows(group, limit){ return toBarRows(group || {}, limit || 6); }
  function empStatusCounts(items){ return empCounts(items, r => trStatus(r.status || 'غير محدد')); }
  function empBarChart(title, hint, rows, limit){
    rows = (rows || []).filter(r => Number(r[1]) > 0).slice(0, limit || 6);
    const max = Math.max(...rows.map(r=>Number(r[1])||0), 1);
    return '<div class="emp-chart-card"><h4>'+title+'</h4><div class="hint">'+hint+'</div><div class="emp-vbars">'+(rows.map(([label,value])=>'<div class="emp-vbar-wrap"><div class="emp-vbar" style="height:'+Math.max(14,(Number(value)||0)/max*180)+'px">'+value+'</div><div class="emp-vbar-label" title="'+empSafeLabel(label)+'">'+empSafeLabel(label)+'</div></div>').join('') || '<div class="soft-note">'+(isEn()?'No data available.':'لا توجد بيانات.')+'</div>')+'</div></div>';
  }
  function empHorizontalChart(title, hint, rows, limit){
    rows = (rows || []).filter(r => Number(r[1]) > 0).slice(0, limit || 7);
    const max = Math.max(...rows.map(r=>Number(r[1])||0), 1);
    return '<div class="emp-chart-card"><h4>'+title+'</h4><div class="hint">'+hint+'</div>'+ (rows.map(([label,value])=>'<div class="emp-hrow"><div class="emp-hlabel" title="'+empSafeLabel(label)+'">'+empSafeLabel(label)+'</div><div class="emp-htrack"><div class="emp-hfill" style="width:'+Math.max(3,(Number(value)||0)/max*100)+'%"></div></div><div class="emp-hvalue">'+value+'</div></div>').join('') || '<div class="soft-note">'+(isEn()?'No data available.':'لا توجد بيانات.')+'</div>') +'</div>';
  }
  function empDonutChart(title, hint, group){
    const palette = ['#2563eb','#38bdf8','#f59e0b','#22c55e','#ef4444','#7c3aed'];
    const entries = Object.entries(group || {}).filter(([,v])=>Number(v)>0).slice(0,6);
    const total = entries.reduce((sum,entry)=>sum+Number(entry[1]||0),0) || 0;
    let acc = 0; const denom = total || 1;
    const stops = entries.map(([k,v],i)=>{ const start=acc; acc += Number(v)/denom*100; return palette[i%palette.length]+' '+start+'% '+acc+'%'; }).join(', ');
    return '<div class="emp-chart-card"><h4>'+title+'</h4><div class="hint">'+hint+'</div><div class="emp-donut-wrap"><div class="emp-donut" style="background:conic-gradient('+(stops || '#cbd5e1 0 100%')+')"><div class="emp-donut-center">'+total+'</div></div><div class="emp-legend">'+(entries.map(([k,v],i)=>'<div class="emp-legend-row"><div class="emp-legend-name"><span class="emp-dot" style="background:'+palette[i%palette.length]+'"></span><span>'+empSafeLabel(k)+'</span></div><strong>'+v+'</strong></div>').join('') || '<div class="soft-note">'+(isEn()?'No breakdown available.':'لا يوجد توزيع متاح.')+'</div>')+'</div></div></div>';
  }
  function empStackedChart(title, hint, rows){
    const palette = ['#2563eb','#f59e0b','#22c55e','#ef4444'];
    return '<div class="emp-chart-card"><h4>'+title+'</h4><div class="hint">'+hint+'</div>'+((rows||[]).map(row=>{ const vals=row.values||[]; const total=vals.reduce((s,v)=>s+Number(v||0),0)||1; return '<div class="emp-stack-row"><div class="emp-hlabel">'+empSafeLabel(row.label)+'</div><div class="emp-stack">'+vals.map((v,i)=>'<div class="emp-seg" title="'+v+'" style="width:'+(Number(v)/total*100)+'%;background:'+palette[i%palette.length]+'"></div>').join('')+'</div><div class="emp-hvalue">'+total+'</div></div>'; }).join('') || '<div class="soft-note">'+(isEn()?'No data available.':'لا توجد بيانات.')+'</div>')+'</div>';
  }
  function empHeatmap(title, hint, cells){ return '<div class="emp-chart-card"><h4>'+title+'</h4><div class="hint">'+hint+'</div><div class="emp-heat">'+((cells||[]).map(c=>'<div class="emp-heat-cell"><span>'+c.label+'</span><strong>'+c.value+'</strong><span>'+(c.note||'')+'</span></div>').join(''))+'</div></div>'; }
  function empFunnelChart(title, hint, rows){ rows = rows || []; const max = Math.max(...rows.map(r=>Number(r[1])||0), 1); return '<div class="emp-chart-card"><h4>'+title+'</h4><div class="hint">'+hint+'</div><div class="emp-funnel">'+rows.map(([label,value])=>'<div class="emp-funnel-step" style="width:'+Math.max(42,Number(value)/max*100)+'%">'+empSafeLabel(label)+' · '+value+'</div>').join('')+'</div></div>'; }
