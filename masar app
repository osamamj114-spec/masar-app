/* ===== Header controls, menu, notification, quality, payments ===== */
.topbar{
  position:relative;
}
.topbar-right{
  display:flex;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
  margin-inline-start:auto;
}
.menu-wrap{position:relative}
.menu-btn,.bell-btn{
  width:52px;height:52px;border-radius:18px;border:1px solid var(--line);
  background:var(--card);color:var(--text);cursor:pointer;font:inherit;font-weight:900;
  display:flex;align-items:center;justify-content:center;position:relative;
  box-shadow:0 10px 24px rgba(15,23,42,.06);
}
.menu-btn:hover,.bell-btn:hover{transform:translateY(-1px)}
.menu-lines,.menu-lines::before,.menu-lines::after{
  content:"";display:block;width:20px;height:2px;background:currentColor;border-radius:99px;position:relative;
}
.menu-lines::before{position:absolute;top:-6px;left:0}
.menu-lines::after{position:absolute;top:6px;left:0}
.bell-badge{
  position:absolute;top:8px;left:8px;min-width:22px;height:22px;padding:0 6px;border-radius:999px;
  background:#dc2626;color:#fff;font-size:11px;font-weight:900;display:flex;align-items:center;justify-content:center;
  border:2px solid var(--card);
}
.menu-dropdown{
  position:absolute;top:62px;inset-inline-end:0;min-width:250px;background:var(--card);border:1px solid var(--line);
  border-radius:22px;box-shadow:0 18px 40px rgba(15,23,42,.14);padding:10px;display:none;z-index:100;
}
.menu-dropdown.open{display:block}
.menu-item{
  width:100%;border:0;background:transparent;color:var(--text);padding:14px 14px;border-radius:16px;
  display:flex;align-items:center;justify-content:space-between;cursor:pointer;font:inherit;font-weight:800;
}
.menu-item:hover{background:rgba(37,99,235,.08)}
.menu-sep{height:1px;background:var(--line);margin:8px 4px}
.portal-badge{
  display:inline-flex;align-items:center;gap:8px;padding:10px 14px;border-radius:16px;
  background:linear-gradient(180deg, rgba(37,99,235,.08), rgba(14,165,233,.05));border:1px solid var(--line);font-weight:800;
}
body.dark .menu-dropdown{box-shadow:0 18px 40px rgba(0,0,0,.34)}
.account-tab{
  border:1px solid transparent;
}
.account-tab.active{
  border-color:rgba(255,255,255,.14);
}
.account-tab:not(.active):hover{
  background:rgba(255,255,255,.06);
}
.entry-login-btn{
  letter-spacing:.2px;
}
.quality-options{
  display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:14px;
}
.quality-btn{
  border:1px solid var(--line);background:var(--card);color:var(--text);border-radius:20px;padding:18px 14px;cursor:pointer;
  text-align:center;font:inherit;font-weight:900;
}
.quality-btn .emoji{font-size:28px;display:block;margin-bottom:8px}
.quality-btn small{display:block;color:var(--muted);margin-top:6px;font-weight:700}
.quality-btn.good-choice{box-shadow:0 0 0 2px rgba(21,128,61,.14)}
.quality-btn.good-choice.active{border-color:#15803d;background:rgba(21,128,61,.08)}
.quality-btn.mid-choice{box-shadow:0 0 0 2px rgba(217,119,6,.14)}
.quality-btn.mid-choice.active{border-color:#d97706;background:rgba(217,119,6,.08)}
.quality-btn.bad-choice{box-shadow:0 0 0 2px rgba(220,38,38,.14)}
.quality-btn.bad-choice.active{border-color:#dc2626;background:rgba(220,38,38,.08)}
.quality-status{
  margin-top:14px;padding:14px;border-radius:18px;border:1px solid var(--line);background:linear-gradient(180deg, rgba(37,99,235,.05), rgba(14,165,233,.03));
  line-height:1.8;
}
.quality-form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-top:14px}
.quality-form-grid .field{min-width:0}
.quality-meta-note{margin-top:10px;color:var(--muted);font-size:13px;line-height:1.8}
.payment-methods{display:grid;gap:12px;margin-top:12px}
.payment-card{
  background:var(--card);border:1px solid var(--line);border-radius:18px;padding:14px;
}
.payment-card .row{align-items:flex-start}
.payment-logo-row{display:flex;gap:10px;flex-wrap:wrap;margin-top:14px}
.pay-logo{
  display:inline-flex;align-items:center;justify-content:center;gap:8px;
  min-width:120px;height:52px;padding:0 16px;border-radius:16px;
  background:linear-gradient(180deg, rgba(37,99,235,.10), rgba(14,165,233,.06));
  border:1px solid var(--line);font-weight:900;color:var(--text)
}
.pay-logo.apple{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif}
.pay-logo .mini-mark{
  width:28px;height:28px;border-radius:10px;display:inline-flex;align-items:center;justify-content:center;
  background:rgba(37,99,235,.14);color:#2563eb;font-size:15px;font-weight:900
}
.violation-card{background:var(--card);border:1px solid var(--line);border-radius:22px;padding:16px}
.violation-card .meta{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
@media (max-width:760px){
  .topbar-right{width:100%;justify-content:space-between}
  .quality-options,.quality-form-grid{grid-template-columns:1fr}
  .menu-dropdown{inset-inline:0;min-width:auto}
}

.countdown-row{display:flex;gap:8px;flex-wrap:wrap;margin-top:10px}
.countdown-badge{display:inline-flex;align-items:center;padding:6px 10px;border-radius:999px;font-size:12px;font-weight:800;background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe}
