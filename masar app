  function normalizeLanguageUI(root = document.body){
    if(!root) return;
    if(isEn()){
      root.querySelectorAll('*').forEach(el => {
        if(el.children.length === 0){
          const txt = (el.textContent || '').trim();
          if(txt){
            const translated = translateLooseText(txt);
            if(translated !== txt) el.textContent = translated;
          }
        }
        if(el.placeholder){
          const translatedPh = translateLooseText(el.placeholder);
          if(translatedPh !== el.placeholder) el.placeholder = translatedPh;
        }
        if(el.title){
          const translatedTitle = translateLooseText(el.title);
          if(translatedTitle !== el.title) el.title = translatedTitle;
        }
      });
    }
  }

