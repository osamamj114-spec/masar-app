.company-bars{display:grid;gap:12px}.company-bar-row{display:grid;grid-template-columns:120px 1fr 40px;gap:10px;align-items:center}.company-bar-label{font-size:13px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.company-bar-track{height:13px;border-radius:999px;background:rgba(148,163,184,.18);overflow:hidden}.company-bar-fill{height:100%;border-radius:999px;background:linear-gradient(90deg,var(--brand-2),var(--brand-3));min-width:6%}.company-bar-value{text-align:end;font-weight:900;font-size:13px}
.company-wave{height:160px;display:flex;align-items:end;gap:8px;padding-top:8px}.company-wave-col{flex:1;display:flex;flex-direction:column;align-items:center;gap:8px}.company-wave-fill{width:100%;border-radius:18px 18px 8px 8px;background:linear-gradient(180deg,#22c55e,var(--brand-2));min-height:18px}.company-wave-label{font-size:11px;color:var(--muted)}
.company-radial-set{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}.company-radial{aspect-ratio:1;border-radius:50%;display:grid;place-items:center;position:relative;background:conic-gradient(var(--brand-2) var(--p), rgba(148,163,184,.18) 0)}.company-radial:after{content:"";position:absolute;inset:13px;background:var(--card);border-radius:50%;border:1px solid var(--line)}.company-radial-inner{position:relative;z-index:2;text-align:center;font-weight:900}.company-radial-inner small{display:block;color:var(--muted);font-size:11px;margin-top:3px}
.company-funnel{display:grid;gap:8px;align-items:center}.company-funnel-step{margin:auto;height:38px;border-radius:14px;background:linear-gradient(90deg,var(--brand-2),var(--brand-3));display:flex;align-items:center;justify-content:center;color:white;font-weight:900;font-size:13px}.company-funnel-step:nth-child(2){width:88%}.company-funnel-step:nth-child(3){width:72%}.company-funnel-step:nth-child(4){width:56%;background:linear-gradient(90deg,#f59e0b,#f97316)}.company-funnel-step:nth-child(5){width:42%;background:linear-gradient(90deg,#22c55e,#16a34a)}
.company-risk-matrix{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}.company-risk-cell{min-height:64px;border-radius:16px;border:1px solid var(--line);background:rgba(37,99,235,.06);display:flex;flex-direction:column;align-items:center;justify-content:center;font-weight:900}.company-risk-cell strong{font-size:20px}.company-risk-cell small{color:var(--muted);font-size:11px}.company-risk-cell.hot{background:rgba(239,68,68,.12)}.company-risk-cell.warm{background:rgba(245,158,11,.14)}.company-risk-cell.good{background:rgba(34,197,94,.12)}
.company-timeline-chart{display:grid;grid-template-columns:repeat(5,1fr);gap:10px}.company-stage{border:1px solid var(--line);border-radius:18px;padding:14px;background:linear-gradient(180deg, rgba(37,99,235,.05), rgba(14,165,233,.03));position:relative}.company-stage:not(:last-child):after{content:"";position:absolute;top:50%;inset-inline-end:-10px;width:10px;height:2px;background:var(--line)}.company-stage b{font-size:22px}.company-stage span{display:block;color:var(--muted);font-size:12px;margin-top:6px;line-height:1.5}
.company-payment-stack{height:190px;border-radius:20px;border:1px solid var(--line);overflow:hidden;display:flex;flex-direction:column-reverse}.company-stack-part{display:flex;align-items:center;justify-content:center;color:#fff;font-weight:900;min-height:24px}.company-stack-part.mada{background:#2563eb}.company-stack-part.apple{background:#0f172a}.company-stack-part.bank{background:#64748b}.company-stack-part.wallet{background:#22c55e}
@media(max-width:1100px){.company-chart-grid,.company-chart-grid.three{grid-template-columns:1fr}.company-radial-set,.company-timeline-chart{grid-template-columns:1fr 1fr}.company-bar-row{grid-template-columns:90px 1fr 36px}}
@media(max-width:640px){.company-radial-set,.company-timeline-chart,.company-risk-matrix{grid-template-columns:1fr 1fr}}

