  function startOfToday(){
    const d = new Date();
    d.setHours(0,0,0,0);
    return d;
  }

  function daysDiffFromToday(dateStr){
    if(!dateStr || /^غير محدد|Not set$/i.test(String(dateStr))) return null;
    const target = new Date(dateStr + 'T00:00:00');
    if (isNaN(target.getTime())) return null;
    const diff = target.getTime() - startOfToday().getTime();
    return Math.round(diff / 86400000);
  }

  function countdownText(kind, dateStr){
    const days = daysDiffFromToday(dateStr);
    if(days === null) return isEn() ? `${kind === 'start' ? 'Start' : 'End'} date not set` : `${kind === 'start' ? 'البداية' : 'النهاية'} غير محددة`;
    if(kind === 'start'){
      if(days > 0) return isEn() ? `${days} day${days===1?'':'s'} left to start` : `متبقي ${days} يوم ${days===1?'':' ' }لبداية الحفر`;
      if(days === 0) return isEn() ? 'Starts today' : 'تبدأ اليوم';
      const past = Math.abs(days);
      return isEn() ? `Started ${past} day${past===1?'':'s'} ago` : `بدأت منذ ${past} يوم`;
    }
    if(days > 0) return isEn() ? `${days} day${days===1?'':'s'} left to finish` : `متبقي ${days} يوم لنهاية الحفر`;
    if(days === 0) return isEn() ? 'Ends today' : 'تنتهي اليوم';
    const past = Math.abs(days);
    return isEn() ? `Ended ${past} day${past===1?'':'s'} ago` : `انتهت منذ ${past} يوم`;
  }

  function countdownHTML(startDate, endDate){
    return `<div class="countdown-row"><span class="countdown-badge">${countdownText('start', startDate)}</span><span class="countdown-badge">${countdownText('end', endDate)}</span></div>`;
  }
