  function escHtml(value){
    return String(value ?? '')
      .replace(/&/g,'&amp;')
      .replace(/</g,'&lt;')
      .replace(/>/g,'&gt;')
      .replace(/"/g,'&quot;')
      .replace(/'/g,'&#39;');
  }

  function formatPortalDateTime(){
    const locale = isEn() ? 'en-GB' : 'ar-SA';
    return new Date().toLocaleString(locale, {year:'numeric', month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit'});
  }

  function numValue(value){
    const cleaned = String(value ?? '').replace(/,/g,'').replace(/SAR/gi,'').trim();
    const n = Number(cleaned);
    return Number.isFinite(n) ? n : 0;
  }
  function formatShortNumber(value){
    const n = Number(value) || 0;
    if(n >= 1000000) return (n/1000000).toFixed(1).replace('.0','') + 'M';
    if(n >= 1000) return (n/1000).toFixed(1).replace('.0','') + 'K';
    return String(Math.round(n));
  }
  function groupSum(items, keyFn, valueFn){
    return items.reduce((acc, item) => {
      const key = keyFn(item) || (isEn() ? 'Not specified' : 'غير محدد');
      acc[key] = (acc[key] || 0) + (valueFn ? valueFn(item) : 1);
      return acc;
    }, {});
  }
  function toBarRows(group, limit=8){ return Object.entries(group).sort((a,b)=>b[1]-a[1]).slice(0,limit); }
  function renderBars(rows, formatter){
    const max = Math.max(1, ...rows.map(r => Number(r[1]) || 0));
    return `<div class="viz-bars">${rows.map(([name,value]) => `
      <div class="viz-bar-row">
        <div class="viz-name">${escHtml(name)}</div>
        <div class="viz-track"><div class="viz-fill" style="width:${Math.max(4, Math.round((Number(value)||0)/max*100))}%"></div></div>
        <div class="viz-value">${escHtml(formatter ? formatter(value) : value)}</div>
      </div>`).join('')}</div>`;
  }
  function renderStatusBreakdown(group){
    return `<div class="viz-stack">${toBarRows(group,8).map(([name,value]) => `
      <div class="viz-status-row"><strong>${escHtml(name)}</strong><span>${escHtml(value)}</span></div>`).join('')}</div>`;
  }
  function renderKpis(items){
    return `<div class="data-viz-grid">${items.map(item => `<div class="data-viz-card"><div class="k">${escHtml(item[0])}</div><div class="v">${escHtml(item[1])}</div><div class="s">${escHtml(item[2] || '')}</div></div>`).join('')}</div>`;
  }

  function exportCurrentDataSheet(){
    const rows = buildPortalDataRows(state.adminDataTab);
    if(!rows.length){ alert(isEn() ? 'No data is ready to export yet.' : 'لا توجد بيانات جاهزة للتصدير الآن.'); return; }
    const headers = ['Snapshot date','Portal','Street / road','Company','Location','Request / case no.','Status','Start date','End date','Days to start','Days to end'];
    const csv = [headers.join(','), ...rows.map(row => [row.snapshotDate,row.portal,row.street,row.company,row.location,row.requestNo,row.status,row.start,row.end,row.daysToStart,row.daysToEnd].map(v => `"${String(v ?? '').replace(/"/g,'""')}"`).join(','))].join('\n');
    const blob = new Blob([csv], {type:'text/csv;charset=utf-8'});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url; a.download = `masar_${state.adminDataTab}_${new Date().toISOString().slice(0,10)}.csv`;
    document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
  }
