  function dateDiffDays(dateStr){
    if(!dateStr) return 0;
    const today = new Date('2026-04-22T00:00:00');
    const target = new Date(`${dateStr}T00:00:00`);
    if(Number.isNaN(target.getTime())) return 0;
    const diff = Math.round((today - target) / (1000 * 60 * 60 * 24));
    return diff > 0 ? diff : 0;
  }

  function reportAgeDays(report){
    if(report.channel === 'citizen'){
      if(report.status === 'تحت المعالجة') return 4;
      if(report.status === 'تم الاستلام') return 2;
      return 1;
    }
    const req = report.requestId ? findRequestById(report.requestId) : null;
    if(req && req.submittedOn) return dateDiffDays(req.submittedOn);
    return report.status === 'عاجل' ? 5 : 2;
  }

  function buildStreetPriorityRows(){
    const grouped = {};
    const combined = [
      ...state.reports.map(r => ({
        source:'citizen',
        location:r.location,
        title:r.title,
        description:r.description,
        requestId:'',
        status:r.status,
        category: classifyEmployeePortalIssue(r)
      })),
      ...state.companyReports.map(r => ({
        source:'company',
        location:r.location,
        title:r.title,
        description:r.action,
        requestId:r.requestId,
        status:r.status,
        category: classifyEmployeePortalIssue(r)
      }))
    ];

    combined.forEach(item => {
      const key = normalizeAdminStreetLocation(item.location);
      if(!grouped[key]){
        grouped[key] = {
          street:key,
          asphalt:0,
          potholes:0,
          general:0,
          delayDays:0,
          citizenReports:0,
          companyReports:0,
          totalReports:0
        };
      }
      grouped[key].totalReports += 1;
      grouped[key].delayDays += reportAgeDays({channel:item.source, status:item.status, requestId:item.requestId});
      if(item.source === 'citizen') grouped[key].citizenReports += 1;
      if(item.source === 'company') grouped[key].companyReports += 1;
      if(item.category === 'asphalt') grouped[key].asphalt += 1;
      else if(item.category === 'potholes') grouped[key].potholes += 1;
      else grouped[key].general += 1;
    });

    return Object.values(grouped).map(row => {
      const score = (row.asphalt * 3) + (row.potholes * 2) + (row.general * 1) + (row.delayDays * 0.5);
      let status = 'NORMAL';
      if(score >= 20) status = 'CRITICAL';
      else if(score >= 10) status = 'WARNING';
      return {...row, score, status};
    }).sort((a,b) => b.score - a.score);
  }

