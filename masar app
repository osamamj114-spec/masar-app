  function setAdminDecision(type){
    const r = getSelectedAdminRequest();
    if(!r) return;
    const today = new Date().toISOString().slice(0,10);
    if(type === 'approve'){
      r.status = 'معتمد';
      r.comments = isEn() ? 'Approved by employee review. The company must follow the approved execution window and public notification requirements.' : 'تم اعتماد الطلب من قبل الموظف المراجع. يجب على الجهة الالتزام بموعد التنفيذ المعتمد ومتطلبات الإشعار العام.';
      r.nextAction = isEn() ? 'Track approved execution date' : 'متابعة موعد التنفيذ المعتمد';
      r.timeline.push(isEn() ? `Approved by employee review on ${today}` : `تم اعتماد الطلب من قبل الموظف بتاريخ ${today}`);
      state.companyNotifications.unshift({title:isEn() ? `Approved ${r.id}` : `تم اعتماد ${r.id}`, body:isEn() ? 'The request is now approved and ready for execution follow-up.' : 'أصبح الطلب معتمدًا وجاهزًا لمتابعة التنفيذ.', badge:isEn() ? 'Approved' : 'اعتماد'});
    } else if(type === 'revise'){
      r.status = 'مطلوب تعديل';
      r.comments = isEn() ? 'Revision required: update the detour plan and ensure the attachment package is complete before resubmission.' : 'مطلوب تعديل: حدّث خطة التحويلة وتأكد من اكتمال حزمة المرفقات قبل إعادة الإرسال.';
      r.nextAction = isEn() ? 'Upload missing attachment and resubmit' : 'رفع المرفق الناقص وإعادة الإرسال';
      r.timeline.push(isEn() ? `Returned for revision on ${today}` : `تمت إعادة الطلب للتعديل بتاريخ ${today}`);
      state.companyNotifications.unshift({title:isEn() ? `Revision required ${r.id}` : `مطلوب تعديل ${r.id}`, body:isEn() ? 'The request was returned with reviewer notes and needs update before resubmission.' : 'تمت إعادة الطلب مع ملاحظات المراجع ويحتاج تحديثًا قبل إعادة الإرسال.', badge:isEn() ? 'Revision' : 'تعديل'});
    } else {
      r.status = 'مرفوض';
      r.comments = isEn() ? 'Rejected after employee review due to unresolved conflict or insufficient supporting data.' : 'تم رفض الطلب بعد مراجعة الموظف بسبب تعارض غير محسوم أو عدم كفاية البيانات المساندة.';
      r.nextAction = isEn() ? 'Prepare the request again before resubmission' : 'إعادة تجهيز الطلب قبل التقديم من جديد';
