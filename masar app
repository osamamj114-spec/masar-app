  function classifyEmployeePortalIssue(item){
    const source = `${item.title || ''} ${item.description || ''} ${item.action || ''}`;
    if(/سفلت|رصف|asphalt|pav/i.test(source)) return 'asphalt';
    if(/هبوط|حفرة|تشققات|pothole|crack/i.test(source)) return 'potholes';
    return 'general';
  }

  function findRequestById(requestId){
