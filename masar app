<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Masar | مسار - Smart Roadworks Coordination Platform</title>
  <style>

    :root{
      --bg:#f4f7fb; --bg2:#eef3f9; --card:#ffffff; --text:#0f172a; --muted:#64748b; --line:#dbe4ee;
      --brand:#0f172a; --brand-2:#1d4ed8; --brand-3:#0ea5e9; --good:#15803d; --warn:#d97706; --danger:#dc2626; --violet:#7c3aed;
      --shadow:0 18px 50px rgba(15,23,42,.08); --radius:24px;
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{margin:0;font-family:Inter,Segoe UI,Tahoma,Arial,sans-serif;background:linear-gradient(180deg,var(--bg),var(--bg2));color:var(--text)}
    .hidden{display:none!important}
    .wrap{max-width:1440px;margin:auto;padding:24px}
    .hero{
      min-height:100vh;
      background:
        radial-gradient(circle at top right, rgba(14,165,233,.16), transparent 24%),
        radial-gradient(circle at bottom left, rgba(29,78,216,.12), transparent 22%),
        linear-gradient(135deg,#0b1220,#0f172a 55%, #16233d);
      color:#fff; display:flex; align-items:center;
    }
    .hero-shell{display:grid;grid-template-columns:1.15fr .85fr;gap:28px;align-items:stretch;width:100%}
    .hero-panel,.hero-actions,.surface,.sidebar,.shell,.pane,.kpi,.case-card,.feed-card,.mini-card,.toolbar,.brandbar,.detour-card,.timeline-card,.table-card,.chart-card,.queue-card{
      background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);backdrop-filter:blur(12px);box-shadow:var(--shadow)
    }
    .hero-panel{border-radius:34px;padding:34px;position:relative;overflow:hidden}
    .hero-actions{border-radius:34px;padding:24px;display:flex;flex-direction:column;gap:16px;justify-content:center}
    .chip{display:inline-flex;align-items:center;gap:10px;padding:10px 16px;border-radius:999px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.14);font-size:14px;margin-bottom:16px}
    .brand-lockup{display:flex;align-items:center;gap:16px;margin-bottom:18px}
    .hero h1{font-size:50px;line-height:1.05;margin:0 0 12px}
    .hero p{color:#d8e2f0;line-height:1.9;font-size:17px;margin:0}
    .hero-subgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:22px}
    .hero-stat{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:22px;padding:16px}
    .hero-stat .k{font-size:12px;color:#cfe0f7}
    .hero-stat .v{font-size:28px;font-weight:800;margin-top:8px}
    .mode-card{padding:22px;border-radius:26px;cursor:pointer;transition:.22s;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12)}
    .mode-card:hover{transform:translateY(-4px);background:rgba(255,255,255,.1)}
    .mode-card h3{margin:0 0 10px;font-size:24px}
    .mode-card p{font-size:15px;color:#d8e2f0}
    .mode-card .go{margin-top:12px;font-weight:800;display:inline-block}
    .shell{display:grid;grid-template-columns:280px 1fr;gap:18px;min-height:100vh;background:transparent;border:none;box-shadow:none}
    .sidebar{background:linear-gradient(180deg,#0f172a,#16233d);color:#fff;border-radius:30px;padding:20px;position:sticky;top:14px;height:calc(100vh - 28px)}
    .brandbar{background:rgba(255,255,255,.08);border-radius:24px;padding:16px;display:flex;align-items:center;gap:14px;margin-bottom:18px}
    .brandtext .en{font-size:20px;font-weight:800}.brandtext .ar{font-size:16px;color:#d8e2f0}
    .nav-group{display:grid;gap:8px;margin-bottom:18px}
    .nav-title{font-size:12px;color:#9fb1c7;text-transform:uppercase;letter-spacing:.12em;margin:10px 8px 4px}
    .nav-btn{border:0;background:transparent;color:#e2ebf6;text-align:left;padding:14px 16px;border-radius:18px;cursor:pointer;font:inherit;font-weight:700;display:flex;align-items:center;justify-content:space-between}
    .nav-btn:hover,.nav-btn.active{background:rgba(255,255,255,.1)}
    .side-note{margin-top:auto;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);padding:16px;border-radius:22px;color:#d6e3f3;line-height:1.7}
    .main{padding:4px 0 24px}
    .toolbar{background:var(--card);border:1px solid var(--line);padding:18px 20px;border-radius:28px;display:flex;justify-content:space-between;gap:18px;align-items:center;margin-bottom:18px}
    .title h2{margin:0;font-size:30px}.title p{margin:6px 0 0;color:var(--muted)}
    .actions{display:flex;gap:10px;flex-wrap:wrap}
    .btn,.ghost,.tab,.pill{border:0;border-radius:16px;padding:12px 16px;font:inherit;font-weight:800;cursor:pointer}
    .btn{background:var(--brand);color:#fff}.ghost{background:#fff;color:var(--text);border:1px solid var(--line)}.ghost.active{background:var(--brand);color:#fff;border-color:var(--brand)}.pill{background:#eff6ff;color:#1d4ed8}
    .page{display:none}.page.active{display:block}
    .section-title{display:flex;justify-content:space-between;align-items:end;gap:16px;margin:8px 0 14px}
    .section-title h3{margin:0;font-size:24px}.section-title p{margin:6px 0 0;color:var(--muted)}
    .kpis{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-bottom:18px}
    .kpi{background:var(--card);border:1px solid var(--line);border-radius:24px;padding:18px}
    .kpi .label{color:var(--muted);font-size:13px;line-height:1.55}.kpi .value{font-size:30px;font-weight:800;margin-top:8px}.kpi .delta{margin-top:8px;font-size:13px;font-weight:700}
    .good{color:var(--good)} .warn{color:var(--warn)} .danger{color:var(--danger)} .violet{color:var(--violet)}
    .dashboard-grid{display:grid;grid-template-columns:1.2fr .8fr;gap:18px}
    .surface{background:var(--card);border:1px solid var(--line);border-radius:28px;padding:18px}
    .surface h3{margin:0 0 6px;font-size:22px}.sub{color:var(--muted);margin:0 0 16px;line-height:1.8}
    .chart-card,.table-card,.queue-card{background:#fff;border:1px solid var(--line);border-radius:24px;padding:18px}
    .chart-bars{display:flex;align-items:end;gap:12px;height:220px;padding-top:12px}
    .bar-wrap{flex:1;text-align:center}
    .bar{border-radius:18px 18px 10px 10px;background:linear-gradient(180deg,var(--brand-3),var(--brand-2));width:100%;min-height:24px;display:flex;align-items:start;justify-content:center;color:#fff;font-weight:800;padding-top:8px}
    .bar-label{margin-top:10px;font-size:13px;color:var(--muted);line-height:1.5}
    .donut{width:220px;height:220px;border-radius:50%;position:relative;margin:auto}
    .donut::after{content:"";position:absolute;inset:30px;background:#fff;border-radius:50%}
    .donut-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:2;font-weight:800}
    .legend{display:grid;gap:10px;margin-top:18px}
    .legend-item{display:flex;align-items:center;justify-content:space-between;gap:12px}
    .dot{width:12px;height:12px;border-radius:50%}
    .ops-grid,.citizen-grid,.institution-grid{display:grid;grid-template-columns:1.08fr .92fr;gap:18px}
    .controls{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px}
    .field{flex:1;min-width:180px}
    input,select,textarea{width:100%;padding:13px 14px;border-radius:16px;border:1px solid var(--line);font:inherit;background:#fff}
    .cases,.feed-list,.queue-list,.table-list{display:grid;gap:12px}
    .case-card,.feed-card,.mini-card,.queue-item,.table-row,.detour-card,.timeline-card{background:#fff;border:1px solid var(--line);border-radius:22px;padding:16px}
    .case-card.active{border-color:var(--brand-2);box-shadow:0 0 0 3px rgba(29,78,216,.08)}
    .row{display:flex;justify-content:space-between;align-items:center;gap:12px;flex-wrap:wrap}
    .muted{color:var(--muted)}
    .badge{display:inline-flex;align-items:center;padding:6px 10px;border-radius:999px;font-size:12px;font-weight:800}
    .badge.high{background:#fee2e2;color:#991b1b}.badge.vhigh{background:#dc2626;color:#fff}.badge.medium{background:#fef3c7;color:#92400e}.badge.low{background:#e2fbe8;color:#166534}.badge.status{background:#eef2ff;color:#3730a3}.badge.approved{background:#dcfce7;color:#166534}.badge.pending{background:#fef3c7;color:#92400e}.badge.rejected{background:#fee2e2;color:#991b1b}
    .metric-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-top:14px}
    .metric{background:#f8fbff;border-radius:18px;padding:12px;border:1px solid #e7eef8}.metric .k{font-size:12px;color:var(--muted)}.metric .v{font-weight:800;margin-top:4px}
    .mapbox{height:520px;border-radius:24px;overflow:hidden;border:1px solid var(--line);background:#dbe4ee} iframe{width:100%;height:100%;border:0}
    .note{background:#eff6ff;border:1px solid #bfdbfe;color:#1e3a8a;border-radius:18px;padding:14px;line-height:1.8}
    .split{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .table-head,.table-row{display:grid;grid-template-columns:1.3fr .8fr .7fr .8fr;gap:12px;align-items:center}
    .table-head{font-size:12px;color:var(--muted);padding:0 6px 8px}
    .timeline{display:grid;gap:12px}
    .timeline-point{display:grid;grid-template-columns:18px 1fr;gap:12px;align-items:start}
    .timeline-dot{width:14px;height:14px;border-radius:50%;margin-top:5px;background:linear-gradient(180deg,var(--brand-3),var(--brand-2))}
    .logo{width:64px;height:64px;flex:0 0 64px}.logo.small{width:52px;height:52px;flex-basis:52px}
    .wide-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;margin-top:18px}
    .before-after-bars{display:flex;align-items:end;gap:12px;height:260px}
    .ba-wrap{flex:1;text-align:center}
    .ba-stack{height:220px;display:flex;flex-direction:column;justify-content:end;gap:6px}
    .ba-before,.ba-after{min-height:20px;border-radius:14px 14px 8px 8px;color:#fff;font-size:11px;font-weight:800;display:flex;align-items:flex-start;justify-content:center;padding-top:6px}
    .ba-before{background:linear-gradient(180deg,#94a3b8,#64748b)}
    .ba-after{background:linear-gradient(180deg,var(--brand-3),var(--brand-2))}
    .mini-legend{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:14px}
    .legend-chip{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--muted)}
    .legend-box{width:14px;height:14px;border-radius:4px}
    @media (max-width:1200px){
      .hero-shell,.dashboard-grid,.ops-grid,.citizen-grid,.institution-grid,.shell,.wide-grid{grid-template-columns:1fr}
      .sidebar{position:relative;height:auto}
      .kpis{grid-template-columns:repeat(3,1fr)}
    }
    @media (max-width:760px){
      .wrap{padding:16px}.hero h1{font-size:36px}.hero-subgrid,.kpis,.split,.metric-grid{grid-template-columns:1fr}
      .toolbar{flex-direction:column;align-items:flex-start}.table-head,.table-row{grid-template-columns:1fr}.mapbox{height:360px}
      .before-after-bars{display:grid;height:auto}.ba-stack{height:160px}
    }
  
.lang-toggle-fixed{
  position:fixed; top:16px; right:16px; z-index:9999;
  border:0; border-radius:16px; padding:12px 16px; font:inherit; font-weight:800; cursor:pointer;
  background:#ffffff; color:#0f172a; box-shadow:0 12px 30px rgba(15,23,42,.18); border:1px solid #dbe4ee;
}
html[dir="rtl"] .lang-toggle-fixed{ right:auto; left:16px; }


/* ===== Entry login redesign ===== */
body{font-family:Inter,Segoe UI,Tahoma,Arial,sans-serif}
.lang-toggle-fixed{display:none!important}
.hero{
  position:relative;
  min-height:100vh;
  padding:28px 24px 40px;
  background:
    radial-gradient(circle at 15% 85%, rgba(29,78,216,.24), transparent 28%),
    radial-gradient(circle at 85% 12%, rgba(14,165,233,.18), transparent 22%),
    linear-gradient(180deg,#030712 0%, #081225 45%, #09172d 100%);
  overflow:hidden;
}
.hero::before{
  content:"";
  position:absolute; inset:0;
  background-image:
    linear-gradient(rgba(53,83,124,.12) 1px, transparent 1px),
    linear-gradient(90deg, rgba(53,83,124,.12) 1px, transparent 1px);
  background-size:56px 56px;
  opacity:.75;
  pointer-events:none;
}
.hero::after{
  content:"";
  position:absolute; left:0; right:0; bottom:26%;
  height:220px;
  background:
    radial-gradient(circle at 12% 100%, rgba(56,189,248,.10), transparent 18%),
    radial-gradient(circle at 83% 100%, rgba(56,189,248,.08), transparent 18%);
  pointer-events:none;
}
.entry-stage{position:relative;z-index:2;max-width:1440px;margin:0 auto;min-height:calc(100vh - 68px)}
.entry-topbar{
  display:flex;align-items:center;justify-content:space-between;gap:18px;
  margin-bottom:44px;
}
.entry-top-actions{display:flex;align-items:center;gap:12px;flex-wrap:wrap}
.entry-pill{
  border:1px solid rgba(255,255,255,.10);
  background:rgba(17,24,39,.82);
  color:#e5edf8;
  padding:12px 18px;
  border-radius:999px;
  font:inherit;font-weight:800;cursor:pointer;
  box-shadow:0 10px 30px rgba(2,6,23,.28);
  backdrop-filter:blur(10px);
}
.entry-pill.active,
.entry-pill:hover{transform:translateY(-1px)}
.entry-pill.support{background:linear-gradient(180deg,#2563eb,#1e40af); color:#ffffff; border-color:rgba(255,255,255,.15)}
.entry-brand{
  display:flex;align-items:center;gap:14px;color:#fff;
  padding:8px 0;
}
.entry-brand .logo-badge{
  width:54px;height:54px;border-radius:18px;
  background:rgba(255,255,255,.06);
  border:1px solid rgba(255,255,255,.1);
  display:grid;place-items:center;
  box-shadow:0 12px 30px rgba(2,6,23,.2);
}
.entry-brand-title{font-size:18px;font-weight:900;line-height:1.1}
.entry-brand-sub{font-size:13px;color:#c8d6ea;margin-top:4px}
.entry-center{
  min-height:calc(100vh - 160px);
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
}
.login-wrap{
  width:min(100%, 470px);
}
.login-card{
  position:relative;
  background:linear-gradient(180deg, rgba(8,15,31,.96), rgba(10,18,37,.93));
  border:1px solid rgba(255,255,255,.08);
  border-radius:34px;
  box-shadow:0 28px 80px rgba(2,6,23,.45);
  padding:34px 34px 26px;
  backdrop-filter:blur(16px);
}
.login-card::before{
  content:"";
  position:absolute; inset:0;
  border-radius:34px;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.05);
  pointer-events:none;
}
.login-logo{
  width:60px;height:60px;margin:0 auto 18px;
  border-radius:18px;
  background:rgba(37,99,235,.12);
  border:1px solid rgba(37,99,235,.18);
  display:grid;place-items:center;
}
.login-title{
  margin:0;
  color:#f8fbff;
  font-size:28px;
  text-align:center;
  font-weight:900;
}
.login-subtitle{
  margin:8px 0 26px;
  color:#98a9c4;
  text-align:center;
  font-size:15px;
}
.account-switch{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  background:#050915;
  border:1px solid rgba(255,255,255,.06);
  border-radius:22px;
  padding:6px;
  gap:6px;
  margin-bottom:22px;
}
.account-tab{
  border:0;
  border-radius:16px;
  background:transparent;
  color:#cdd7e7;
  padding:14px 10px;
  font:inherit;
  font-weight:800;
  cursor:pointer;
  transition:.18s ease;
}
.account-tab.active{
  background:linear-gradient(180deg,#2563eb,#1d4ed8);
  color:#ffffff;
  box-shadow:0 10px 22px rgba(37,99,235,.22);
}
.account-tab small{
  display:block;
  font-size:11px;
  opacity:.72;
  margin-top:4px;
}
.entry-label{
  display:block;
  color:#d8e2f0;
  font-size:14px;
  margin:16px 0 10px;
}
.entry-field{
  position:relative;
}
.entry-input{
  width:100%;
  border-radius:18px;
  border:1px solid rgba(255,255,255,.08);
  background:rgba(255,255,255,.06);
  color:#f8fbff;
  padding:16px 18px;
  font:inherit;
  outline:none;
}
.entry-input::placeholder{color:#7f8da5}
.entry-login-btn{
  width:100%;
  margin-top:22px;
  border:0;
  border-radius:18px;
  padding:16px 18px;
  font:inherit;
  font-weight:900;
  cursor:pointer;
  background:linear-gradient(180deg,#2563eb,#1d4ed8);
  color:#ffffff;
  box-shadow:0 18px 32px rgba(37,99,235,.18);
}
.entry-login-btn:hover{transform:translateY(-1px)}
.entry-helper{
  margin-top:18px;
  color:#98a9c4;
  text-align:center;
  font-size:14px;
}
.entry-helper a{
  color:#60a5fa;
  text-decoration:none;
  font-weight:800;
}
.entry-divider{
  display:flex;align-items:center;gap:12px;
  margin:18px 0 16px;
  color:#74849f;
  font-size:13px;
}
.entry-divider::before,.entry-divider::after{
  content:""; flex:1; height:1px; background:rgba(255,255,255,.08);
}
.nafath-login{
  width:100%;
  border:1px dashed rgba(255,255,255,.12);
  background:transparent;
  color:#d8e2f0;
  padding:14px 16px;
  border-radius:18px;
  font:inherit;font-weight:700;cursor:pointer;
  display:flex;align-items:center;justify-content:center;gap:10px;
}
.nafath-dot{
  width:10px;height:10px;border-radius:50%;
  background:#22c55e; box-shadow:0 0 0 6px rgba(34,197,94,.14);
}
.entry-status{
  display:flex;align-items:center;justify-content:center;gap:10px;
  margin:14px auto 0;
  width:max-content; max-width:100%;
  color:#c8d6ea;
  font-size:12px;
  padding:10px 16px;
  border-radius:999px;
  background:rgba(3,7,18,.72);
  border:1px solid rgba(255,255,255,.08);
  backdrop-filter:blur(10px);
}
.entry-status .status-dot{
  width:8px;height:8px;border-radius:50%;background:#22c55e;
  box-shadow:0 0 0 6px rgba(34,197,94,.12);
}
.entry-status .version{
  opacity:.8;
  font-weight:800;
}
.entry-light .hero{
  background:
    radial-gradient(circle at 12% 85%, rgba(29,78,216,.15), transparent 26%),
    radial-gradient(circle at 84% 12%, rgba(14,165,233,.12), transparent 22%),
    linear-gradient(180deg,#eef4fb 0%, #dfeafa 100%);
}
.entry-light .hero::before{
  background-image:
    linear-gradient(rgba(29,78,216,.08) 1px, transparent 1px),
    linear-gradient(90deg, rgba(29,78,216,.08) 1px, transparent 1px);
}
.entry-light .entry-brand{color:#0f172a}
.entry-light .entry-brand-sub{color:#475569}
.entry-light .entry-pill{background:rgba(255,255,255,.88); color:#0f172a; border-color:#dbe4ee}
.entry-light .entry-pill.support{background:linear-gradient(180deg,#2563eb,#1d4ed8); color:#ffffff}
.entry-light .login-card{background:linear-gradient(180deg, rgba(255,255,255,.92), rgba(248,250,252,.96));}
.entry-light .login-title{color:#0f172a}
.entry-light .login-subtitle{color:#64748b}
.entry-light .entry-label{color:#0f172a}
.entry-light .entry-input{background:#fff;border-color:#dbe4ee;color:#0f172a}
.entry-light .account-switch{background:#f8fafc;border-color:#e2e8f0}
.entry-light .account-tab{color:#334155}
.entry-light .nafath-login{color:#0f172a;border-color:#dbe4ee}
.entry-light .entry-helper{color:#64748b}
.entry-light .entry-status{background:rgba(255,255,255,.92);color:#0f172a;border-color:#dbe4ee}
@media (max-width: 860px){
  .entry-topbar{flex-direction:column-reverse;align-items:stretch}
  .entry-brand{justify-content:center}
  .entry-top-actions{justify-content:center}
}

.app-promo{
  width:min(100%, 1180px);
  margin:28px auto 0;
  position:relative;
  z-index:2;
  background:linear-gradient(180deg, rgba(8,15,31,.92), rgba(10,18,37,.88));
  border:1px solid rgba(255,255,255,.08);
  border-radius:34px;
  box-shadow:0 28px 80px rgba(2,6,23,.34);
  padding:28px;
  overflow:hidden;
}
.app-promo::before{
  content:"";
  position:absolute; inset:0;
  background:
    radial-gradient(circle at 15% 80%, rgba(37,99,235,.16), transparent 26%),
    radial-gradient(circle at 82% 22%, rgba(96,165,250,.10), transparent 20%);
  pointer-events:none;
}
.app-promo-grid{
  position:relative;
  z-index:2;
  display:grid;
  grid-template-columns:1.15fr .55fr .95fr;
  gap:24px;
  align-items:center;
}
.promo-devices{
  display:flex;
  align-items:flex-end;
  justify-content:center;
  gap:24px;
  min-height:360px;
}
.phone-mock{
  width:208px;
  height:404px;
  background:#020617;
  border-radius:38px;
  padding:9px;
  box-shadow:0 24px 55px rgba(2,6,23,.48);
  border:2px solid rgba(255,255,255,.26);
  position:relative;
}
.phone-mock.iphone::before{
  content:"";
  position:absolute;
