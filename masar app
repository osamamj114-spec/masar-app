  function applyRole(){
    const cfg = roleCfg();
    qs('#roleSubtitle').textContent = cfg.subtitle;
    qs('#pageTitle').textContent = cfg.title;
    qs('#pageDesc').textContent = cfg.desc;
    qs('#sidebarNote').textContent = cfg.note;
    qs('#navList').innerHTML = cfg.nav.map(item => `
      <button type="button" class="nav-item ${state.page === item.id ? 'active' : ''}" data-page-target="${item.id}">
        <span class="nav-item-main"><span class="nav-ico">${item.icon || '•'}</span><span>${item.label}</span></span><span>${isEn() ? '▸' : '◂'}</span>
      </button>
    `).join('');
    qsa('#navList .nav-item').forEach(btn => {
      btn.addEventListener('click', function(){
        const target = this.dataset.pageTarget;
        if(target) showPage(target);
      });
    });
    applyPortalHeadingIcons();

    const allPages = [
      'citizen-home','citizen-projects','citizen-quality','citizen-map','citizen-notifications','citizen-reports','citizen-support',
      'institution-home','institution-requests','institution-new','institution-notifications','institution-violations','institution-support',
      'admin-home','admin-requests','admin-conflicts','admin-citizen-reports','admin-company-reports','admin-street-priority','admin-payments','admin-data','admin-support'
    ];
    allPages.forEach(id => { const el = qs('#' + id); if(el) el.classList.remove('active'); });

    if(state.role === 'citizen' && !state.page.startsWith('citizen-')) state.page = 'citizen-home';
    if(state.role === 'institution' && !state.page.startsWith('institution-')) state.page = 'institution-home';
    if(state.role === 'admin' && !state.page.startsWith('admin-')) state.page = 'admin-home';
    const page = qs('#' + state.page);
    if(page) page.classList.add('active');
    applyCitizenIcons();
  }

  function showPage(pageId){
    state.page = pageId;
    applyRole();
    if(pageId === 'citizen-map') updateMapPanel();
    if(pageId === 'institution-requests') renderCompanyRequestsPage();
    if(pageId === 'institution-home') renderInstitutionHome();
    if(pageId === 'institution-new') renderCompanyNewCharts();
    if(pageId === 'institution-notifications') { renderCompanyNotifications(); renderCompanyNotificationsCharts(); }
    if(pageId === 'institution-support') renderCompanySupportCharts();
    if(pageId === 'institution-violations') { renderInstitutionViolations(); renderCompanyViolationsCharts(); }
    if(pageId === 'admin-requests') renderAdminRequestsPage();
    if(pageId === 'admin-conflicts') renderAdminConflictsPage();
    if(pageId === 'admin-citizen-reports') renderAdminCitizenReportsPage();
    if(pageId === 'admin-company-reports') renderAdminCompanyReportsPage();
    if(pageId === 'admin-street-priority') renderAdminStreetPriorityPage();
    if(pageId === 'admin-payments') renderAdminPayments();
    if(pageId === 'admin-data') renderAdminDataCenter();
    if(pageId === 'admin-home') renderAdminHome();
    if(pageId === 'admin-support') renderEmployeePageCharts('support');
  }

  function badgeClass(impact){
    if(impact === 'عالٍ') return 'high';
    if(impact === 'متوسط') return 'medium';
    return 'low';
  }

  function statusClass(status){
    if(status === 'معتمد' || status === 'مكتمل') return 'low';
    if(status === 'مطلوب تعديل' || status === 'تحت المراجعة') return 'medium';
    if(status === 'مرفوض') return 'high';
    return 'info';
  }

