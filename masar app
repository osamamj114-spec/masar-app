  /* ===== Company portal chart renderers ===== */
  function companyCountBy(list, fn){ return (list || []).reduce((acc, item) => { const key = fn(item) || '—'; acc[key] = (acc[key] || 0) + 1; return acc; }, {}); }
  function companyTopRows(obj, limit = 5){ return Object.entries(obj || {}).sort((a,b)=>b[1]-a[1]).slice(0,limit); }
  function companyDonut(title, sub, rows, center){
    const total = rows.reduce((s,r)=>s+r[1],0) || 1; const colors = ['var(--brand-2)','var(--brand-3)','#f59e0b','#ef4444','#22c55e']; let at = 0;
    const stops = rows.map((r,i)=>{ const start=at; at += (r[1]/total)*100; return `${colors[i%colors.length]} ${start}% ${at}%`; }).join(', ');
    return `<div class="company-chart-card"><h4>${title}</h4><p>${sub}</p><div class="company-donut" style="background:conic-gradient(${stops})"><div class="company-donut-center"><span>${center || total}</span><small>${isEn()?'Total':'الإجمالي'}</small></div></div><div class="company-legend">${rows.map((r,i)=>`<div class="company-legend-row"><span><i class="company-dot c${i+1}"></i>${escHtml(r[0])}</span><b>${r[1]}</b></div>`).join('')}</div></div>`;
  }
  function companyBars(title, sub, rows){ const max = Math.max(1, ...rows.map(r=>r[1])); return `<div class="company-chart-card"><h4>${title}</h4><p>${sub}</p><div class="company-bars">${rows.map(r=>`<div class="company-bar-row"><div class="company-bar-label">${escHtml(r[0])}</div><div class="company-bar-track"><div class="company-bar-fill" style="width:${Math.max(6, Math.round(r[1]/max*100))}%"></div></div><div class="company-bar-value">${r[1]}</div></div>`).join('')}</div></div>`; }
  function companyWave(title, sub, rows){ const max = Math.max(1, ...rows.map(r=>r[1])); return `<div class="company-chart-card"><h4>${title}</h4><p>${sub}</p><div class="company-wave">${rows.map(r=>`<div class="company-wave-col"><div class="company-wave-fill" style="height:${Math.max(18, Math.round(r[1]/max*145))}px"></div><div class="company-wave-label">${escHtml(r[0])}</div></div>`).join('')}</div></div>`; }
  function companyRadials(title, sub, rows){ return `<div class="company-chart-card"><h4>${title}</h4><p>${sub}</p><div class="company-radial-set">${rows.map(r=>`<div class="company-radial" style="--p:${Math.max(0,Math.min(100,r[1]))}%"><div class="company-radial-inner">${r[1]}%<small>${escHtml(r[0])}</small></div></div>`).join('')}</div></div>`; }
  function companyFunnel(title, sub, rows){ return `<div class="company-chart-card"><h4>${title}</h4><p>${sub}</p><div class="company-funnel">${rows.map(r=>`<div class="company-funnel-step">${escHtml(r[0])} · ${r[1]}</div>`).join('')}</div></div>`; }
  function companyRiskMatrix(title, sub, rows){ return `<div class="company-chart-card"><h4>${title}</h4><p>${sub}</p><div class="company-risk-matrix">${rows.map(r=>`<div class="company-risk-cell ${r[2]||''}"><strong>${r[1]}</strong><small>${escHtml(r[0])}</small></div>`).join('')}</div></div>`; }
  function companyTimelineChart(title, sub, rows){ return `<div class="company-chart-card"><h4>${title}</h4><p>${sub}</p><div class="company-timeline-chart">${rows.map(r=>`<div class="company-stage"><b>${r[1]}</b><span>${escHtml(r[0])}</span></div>`).join('')}</div></div>`; }
  function companyPaymentStack(title, sub, rows){ const total = rows.reduce((a,b)=>a+b[1],0)||1; return `<div class="company-chart-card"><h4>${title}</h4><p>${sub}</p><div class="company-payment-stack">${rows.map(r=>`<div class="company-stack-part ${r[2]}" style="height:${Math.max(14, Math.round(r[1]/total*100))}%">${escHtml(r[0])} · ${r[1]}</div>`).join('')}</div></div>`; }
