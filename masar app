  function previewCompanyAttachment(event){
    const file = event.target.files && event.target.files[0];
    qs('#companyAttachmentName').textContent = file ? (isEn() ? `Selected file: ${file.name}` : `الملف المحدد: ${file.name}`) : (isEn() ? 'No file selected yet' : 'لم يتم اختيار ملف بعد');
    updateCompanyReadiness();
  }

  function updateCompanyReadiness(){
    const attachment = qs('#companyAttachment') && qs('#companyAttachment').files[0];
    const confirm = qs('#companyConfirm') && qs('#companyConfirm').checked;
    const road = qs('#companyRoad') && qs('#companyRoad').value.trim();
    const start = qs('#companyStart') && qs('#companyStart').value;
    const end = qs('#companyEnd') && qs('#companyEnd').value;
    const note = qs('#companyFormReadiness');
    if(!note) return;
    const readyCount = [!!road, !!start, !!end, !!attachment, !!confirm].filter(Boolean).length;
    note.textContent = readyCount >= 5 ? (isEn() ? 'The request is preliminarily ready for submission. Just verify the dates and detour plan.' : 'الطلب جاهز مبدئيًا للإرسال. تأكد فقط من صحة التواريخ وخطة التحويلة.') : (isEn() ? `Current request readiness: ${readyCount}/5. Enter the location and dates, attach a file, and confirm the declaration before submission.` : `جاهزية الطلب الحالية: ${readyCount}/5. أدخل الموقع والتواريخ، أرفق ملفًا، وفعّل التعهد قبل الإرسال.`);
  }

  function submitCompanyRequest(){
    const road = qs('#companyRoad').value.trim();
    const district = qs('#companyDistrict').value;
    const workType = qs('#companyWorkType').value;
    const start = qs('#companyStart').value || 'غير محدد';
    const end = qs('#companyEnd').value || 'غير محدد';
    const closure = qs('#companyClosure').value;
    const points = qs('#companyPoints').value || '1';
    const duration = qs('#companyDuration').value || '1';
    const attachment = qs('#companyAttachment').files[0];
    const confirm = qs('#companyConfirm').checked;
    if(!road){ alert(isEn() ? 'Enter the road or location name first.' : 'أدخل اسم الشارع أو الموقع أولًا.'); return; }
    if(!confirm){ alert(isEn() ? 'Activate the declaration before submitting the request.' : 'فعّل التعهد قبل إرسال الطلب.'); return; }
    const id = 'RQ-' + (3030 + state.companyRequests.length + 1);
    state.companyRequests.unshift({
      id, road, district, workType, status:'جديد', start, end, closure, points, duration,
      comments:isEn() ? 'The request was received in the portal and is waiting for the initial review.' : 'تم استلام الطلب داخل البوابة وبانتظار المراجعة الأولية.',
      company:qs('#companyName').value.trim() || 'جهة غير محددة',
      documents:attachment ? (isEn() ? 'Attachment added' : 'مرفق مضاف') : (isEn() ? 'No attachment' : 'بدون مرفق'),
      attachmentName:attachment ? attachment.name : 'بدون مرفق',
      priority:qs('#companyImpact').value === 'عالٍ' ? 'عالٍ' : 'متوسط',
      impact:qs('#companyImpact').value,
      submittedOn:new Date().toISOString().slice(0,10),
      nextAction:isEn() ? 'Waiting for initial review' : 'انتظار بدء المراجعة الأولية',
      contact:qs('#companyContactName').value.trim() || 'غير محدد',
      phone:qs('#companyContactPhone').value.trim() || 'غير محدد',
      detourPlan:qs('#companyDetourPlan').value.trim() || 'لم تتم إضافة خطة تحويلة تفصيلية',
      timeline:isEn() ? ['Request created in the company portal','The request was received and is waiting for initial review'] : ['تم إنشاء الطلب داخل بوابة الشركات','تم استلام الطلب وبانتظار المراجعة الأولية']
    });
    state.companyNotifications.unshift({title:isEn() ? `Received ${id}` : `تم استلام ${id}`, body:isEn() ? 'The new request was registered in the portal and will enter review soon.' : 'تم تسجيل الطلب الجديد داخل البوابة وسيبدأ مراجعته قريبًا.', badge:isEn() ? 'Received' : 'استلام'});
    state.selectedRequest = id;
    qs('#companySubmitNote').textContent = isEn() ? `Request ${id} was created successfully and added to your requests list.` : `تم إنشاء الطلب ${id} بنجاح وإضافته إلى قائمة طلباتك.`;
    renderInstitutionHome();
    renderCompanyRequestsPage();
    renderCompanyNotifications();
    showPage('institution-requests');
    resetCompanyForm(false);
  }

  function resetCompanyForm(clearNote = true){
    ['companyRoad','companyStart','companyEnd','companyPoints','companyDuration','companyDescription','companyContactName','companyContactPhone','companyDetourPlan'].forEach(id => { const el = qs('#'+id); if(el) el.value = ''; });
    ['docTrafficPlan','docLocationPlan','docSafetyPlan','companyConfirm'].forEach(id => { const el = qs('#'+id); if(el) el.checked = false; });
    const attachment = qs('#companyAttachment'); if(attachment) attachment.value = '';
    qs('#companyAttachmentName').textContent = isEn() ? 'No file selected yet' : 'لم يتم اختيار ملف بعد';
    if(clearNote) qs('#companySubmitNote').textContent = isEn() ? 'Make sure the location, dates, attachments, and detour plan are correct before submission.' : 'تأكد من صحة الموقع، التواريخ، المرفقات، وخطة التحويلة قبل الإرسال.';
    updateCompanyReadiness();
  }

