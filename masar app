  function setIconizedText(selector, icon, cls){
    const el = qs(selector);
    if(!el) return;
    if(!el.dataset.baseText) el.dataset.baseText = el.textContent.trim();
    const base = el.dataset.baseText;
    el.innerHTML = `<span class="${cls}"><span class="pico">${icon}</span><span>${base}</span></span>`;
  }


